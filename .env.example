# Copiez ce fichier en .env et remplissez (voir Cle.md)
# Ne commitez jamais .env ni Cle.md
# Pour inscription sans confirmation mail : Supabase → Authentication → Providers → Email → désactiver "Confirm email"

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# Chatbot (OpenAI) — clé API OpenAI pour le widget de chat (visiteurs non connectés)
VITE_OPENAI_API_KEY=sk-...

# Chatbot 2 (n8n) — webhook pour les utilisateurs connectés (copiez dans .env)
VITE_N8N_WEBHOOK_CHATBOT_USER=